# Supabase (Auth + Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres para Drizzle en runtime (Vercel / serverless):
# En Supabase → Settings → Database usá "Connection string" → Modo **Transaction** (pooler, puerto 6543).
# Ejemplo: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# El puerto 5432 directo suele dar CONNECT_TIMEOUT desde el build o funciones serverless de Vercel.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Cron en Vercel: mismo valor que en el dashboard del proyecto (Vercel → Cron → o variable CRON_SECRET)
CRON_SECRET=

# Zona y moneda (referencia app; por defecto ARS y America/Argentina/Buenos_Aires en código)
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires
NEXT_PUBLIC_DEFAULT_CURRENCY=ARS
