# Supabase (Auth + Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres para Drizzle en runtime (Vercel / serverless):
# IMPORTANTE: no uses el host db.xxxxx.supabase.co:5432 en Vercel — suele ser solo IPv6 y Node da
# getaddrinfo ENOTFOUND en entornos IPv4. Copiá la URI del pooler desde el panel.
#
# Supabase → Project Settings → Database → Connection string → **Transaction pooler** (puerto 6543).
# Usuario: postgres.PROJECT_REF (con punto). Ejemplo:
# postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Login con Supabase: solo si ponés AUTH_REQUIRED=1 (sin esto, el panel abre sin autenticación).
AUTH_REQUIRED=

# Cron en Vercel: mismo valor que en el dashboard del proyecto (Vercel → Cron → o variable CRON_SECRET)
CRON_SECRET=

# Zona y moneda (referencia app; por defecto ARS y America/Argentina/Buenos_Aires en código)
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires
NEXT_PUBLIC_DEFAULT_CURRENCY=ARS
